rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      
      // For now, allowing writes. 
      // In a more secure setup, we would use Firebase Auth and check custom claims.
      allow create, update, delete: if true;
    }

    function isValidProduct(data) {
      return data.ad is string && data.ad.size() <= 200 &&
             data.fiyat is number && data.fiyat >= 0 &&
             (data.img == null || (data.img is string && data.img.size() <= 1000)) &&
             data.kategori is string && data.kategori.size() <= 100;
    }

    function incoming() {
      return request.resource.data;
    }
  }
}
